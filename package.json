{
    "name": "derek-dev-website",
    "description": "Personal dev website for Derek Roemhildt",
    "private": true,
    "packageManager": "pnpm@10.28.2",
    "engines": {
        "node": "24.2.0",
        "pnpm": "10.28.2"
    },
    "engineStrict": true,
    "scripts": {
        "dev": "pnpm --filter ui dev",
        "build": "pnpm --filter ui build",
        "preview": "pnpm --filter ui preview",
        "typecheck": "pnpm --filter ui exec tsc --noEmit",

        "format": "biome format --write .",
        "lint": "biome check .",
        "lint:fix": "biome check --write ."
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.4"
    }
}
