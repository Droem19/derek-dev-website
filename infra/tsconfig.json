{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ES2022"],
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "rootDir": ".",
        "typeRoots": ["./node_modules/@types"]
    },
    "include": ["bin/**/*", "lib/**/*"],
    "exclude": ["node_modules", "cdk.out", "dist"]
}
